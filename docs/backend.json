
{
  "entities": {
    "Building": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Building",
      "type": "object",
      "description": "Represents a physical building asset in the Simpliwork portfolio.",
      "properties": {
        "building_id": { "type": "string" },
        "building_name": { "type": "string" },
        "city": { "type": "string" },
        "cluster": { "type": "string" },
        "active_status": { "type": "boolean" }
      },
      "required": ["building_id", "building_name", "city", "cluster", "active_status"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an internal user of the Simpliwork Deal OS.",
      "properties": {
        "user_id": { "type": "string" },
        "full_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["SALES", "DESIGN", "MANAGEMENT", "ADMIN"] },
        "active_status": { "type": "boolean" }
      },
      "required": ["user_id", "full_name", "email", "role", "active_status"]
    },
    "Deal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Deal",
      "type": "object",
      "description": "Represents a qualified sales opportunity linked to a specific building.",
      "properties": {
        "deal_id": { "type": "string" },
        "company_name": { "type": "string" },
        "building_id": { "type": "string" },
        "sales_owner_email": { "type": "string", "format": "email" },
        "stage": { "type": "string" },
        "stage_updated_date": { "type": "string" },
        "requirement_summary": { "type": "string" },
        "approx_requirement_size": { "type": "number" },
        "source_type": { "type": "string" },
        "source_organisation": { "type": "string" },
        "source_name": { "type": "string" },
        "created_date": { "type": "string" },
        "last_activity_date": { "type": "string" },
        "activity_logs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "user_email": { "type": "string" },
              "timestamp": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "budget_clarity": { "type": "boolean" },
        "timeline_clarity": { "type": "boolean" },
        "decision_maker_identified": { "type": "boolean" },
        "layout_requested_date": { "type": "string" },
        "layout_uploaded_date": { "type": "string" },
        "layout_revision_count": { "type": "number" },
        "design_note": { "type": "string" },
        "layout_file_upload": { "type": "string" },
        "loi_initiated_date": { "type": "string" },
        "loi_signed_date": { "type": "string" },
        "lost_reason": { "type": "string" }
      },
      "required": ["deal_id", "company_name", "building_id", "sales_owner_email", "stage", "created_date"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/buildings/{buildingId}": {
      "schema": "#/backend/entities/Building",
      "description": "Master data for buildings."
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Staff profiles and roles."
    },
    "/deals/{dealId}": {
      "schema": "#/backend/entities/Deal",
      "description": "Sales opportunities."
    }
  }
}
