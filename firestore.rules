rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SIMPLIWORK DEAL OS - SECURITY RULES PHILOSOPHY
     * 
     * Core Philosophy: This ruleset implements a strict internal-only access model. 
     * Access is restricted exclusively to authenticated users with a "@simpliwork.com" 
     * email address.
     * 
     * Data Structure: 
     * - /users: Profile data for every internal user.
     * - /roles_{role_name}: Specialized flag collections for optimized role-based 
     *   access control (RBAC). 
     * - /buildings: Master building assets, managed by Admins, read-only for staff.
     * - /deals: Transactional sales opportunities with ownership and stage-based 
     *   visibility.
     * 
     * Key Security Decisions:
     * - Domain Restriction: Global enforcement of @simpliwork.com identity.
     * - Denormalization: Deal documents contain 'salesOwnerId' and 'stage' to 
     *   allow O(1) security lookups without costly get() calls.
     * - DBAC (Database-Based Access Control): Roles are validated via the 
     *   presence of documents in specific 'roles_' collections, ensuring 
     *   synchronization with Firestore data rather than relying on custom claims.
     * - Prototyping Flexibility: Rules enforce WHO can write but not the 
     *   specific shape of non-relational data.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Restricts access to Simpliwork corporate identities only
    function isSimpliworkUser() {
      return isSignedIn() && request.auth.token.email.matches('.*@simpliwork\\.com$');
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Role existence checks based on denormalized collections
    function hasRole(role) {
      // FIX: Corrected path construction for exists() function - must be a path object
      return exists(path('/databases/$(database)/documents/roles_$(role)/$(request.auth.uid)'));
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isManagement() {
      return hasRole('management');
    }

    function isSales() {
      return hasRole('sales');
    }

    function isDesign() {
      return hasRole('design');
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles. Users can manage their own profiles; 
     *              Admins and Management can view all staff.
     * @path /users/{userId}
     * @allow (get) If requester is the owner, an Admin, or Management.
     * @deny (update) If requester is not the owner or an Admin.
     * @principle Ownership-based writes with administrative oversight.
     */
    match /users/{userId} {
      allow get: if isSimpliworkUser() && (isOwner(userId) || isAdmin() || isManagement());
      allow list: if isSimpliworkUser() && (isAdmin() || isManagement());
      allow create: if isSimpliworkUser() && isOwner(userId);
      allow update: if isSimpliworkUser() && (isOwner(userId) || isAdmin()) && (request.resource.data.id == resource.data.id);
      allow delete: if isSimpliworkUser() && isAdmin();
    }

    /**
     * @description Rules for role identity flags. These are strictly managed by Admins. 
     *              Users can read their own role status to verify permissions.
     * @path /roles_{roleName}/{userId}
     * @allow (get) If requester is checking their own role status or is an Admin.
     * @deny (create/update/delete) For anyone except an Admin.
     * @principle Structural segregation of authorization flags.
     */
    // FIX: Removed /{collection=**}/ as the collection path is fixed
    match /roles_admin/{userId} {
      allow get: if isSimpliworkUser() && (isOwner(userId) || isAdmin());
      allow list: if isSimpliworkUser() && isAdmin();
      allow create, update, delete: if isSimpliworkUser() && isAdmin();
    }
    // FIX: Removed /{collection=**}/ as the collection path is fixed
    match /roles_management/{userId} {
      allow get: if isSimpliworkUser() && (isOwner(userId) || isAdmin() || isManagement());
      allow list: if isSimpliworkUser() && (isAdmin() || isManagement());
      allow create, update, delete: if isSimpliworkUser() && isAdmin();
    }
    // FIX: Removed /{collection=**}/ as the collection path is fixed
    match /roles_sales/{userId} {
      allow get: if isSimpliworkUser() && (isOwner(userId) || isAdmin() || isManagement() || isSales());
      allow list: if isSimpliworkUser() && (isAdmin() || isManagement());
      allow create, update, delete: if isSimpliworkUser() && isAdmin();
    }
    // FIX: Removed /{collection=**}/ as the collection path is fixed
    match /roles_design/{userId} {
      allow get: if isSimpliworkUser() && (isOwner(userId) || isAdmin() || isManagement() || isDesign());
      allow list: if isSimpliworkUser() && (isAdmin() || isManagement());
      allow create, update, delete: if isSimpliworkUser() && isAdmin();
    }

    /**
     * @description Rules for building master data. Visible to all Simpliwork staff; 
     *              modifiable only by Admins.
     * @path /buildings/{buildingId}
     * @allow (get/list) If requester is any signed-in @simpliwork.com user.
     * @deny (write) If requester is not an Admin.
     * @principle Corporate-wide read access for master assets.
     */
    match /buildings/{buildingId} {
      allow get, list: if isSimpliworkUser();
      allow create, update, delete: if isSimpliworkUser() && isAdmin();
    }

    /**
     * @description Rules for Deal records. Visibility is based on ownership (Sales), 
     *              stage (Design), or high-level oversight (Management/Admin).
     * @path /deals/{dealId}
     * @allow (list) Sales can list their own deals; Design can list 'Solutioning' deals.
     * @deny (update) If requester is Sales but not the owner of the specific deal.
     * @principle Content-based authorization via denormalized ownership and stage fields.
     */
    match /deals/{dealId} {
      // READ LOGIC
      allow get: if isSimpliworkUser() && (isAdmin() || isManagement() || (isSales() && resource.data.salesOwnerId == request.auth.uid) || (isDesign() && resource.data.stage == 'Solutioning'));
      allow list: if isSimpliworkUser() && (isAdmin() || isManagement() || isSales() || isDesign());

      // CREATE LOGIC
      // Ensures the creator identifies themselves as the owner during creation.
      allow create: if isSimpliworkUser() && (isAdmin() || (isSales() && request.resource.data.salesOwnerId == request.auth.uid));

      // UPDATE LOGIC
      // 1. Admins can update anything.
      // 2. Sales can update their own deals (ownerId must remain immutable).
      // 3. Design can update deals specifically in the 'Solutioning' stage.
      allow update: if isSimpliworkUser() && resource != null && (isAdmin() || (isSales() && resource.data.salesOwnerId == request.auth.uid && request.resource.data.salesOwnerId == resource.data.salesOwnerId) || (isDesign() && resource.data.stage == 'Solutioning'));

      // DELETE LOGIC
      allow delete: if isSimpliworkUser() && resource != null && isAdmin();
    }
  }
}

/**
 * PROTOTYPING NOTE: 
 * These rules are designed for flexibility. While they strictly enforce 
 * DOMAIN (Simpliwork) and IDENTITY (Ownership/Roles), they do not 
 * validate the specific schema of every field (e.g., 'requirementSummary' 
 * data types) to allow for rapid UI/feature development.
 */

/**
 * DOMAIN SECURITY ALERT:
 * The 'isSimpliworkUser' function relies on the 'email' field in the 
 * Firebase Auth token. Ensure your Google Sign-In configuration is 
 * restricted to the simpliwork.com domain at the GCP project level 
 * for maximum security.
 */

/**
 * RELATIONAL INTEGRITY:
 * Deals are bound to owners via the 'salesOwnerId' field. 
 * The update rule enforces that this ID cannot be changed by 
 * Sales users, preventing 'deal stealing'.
 */

/**
 * QUERY SECURITY:
 * To use the 'list' functionality for Sales or Design, queries must 
 * include the appropriate filters:
 * - Sales: .where('salesOwnerId', '==', currentUser.uid)
 * - Design: .where('stage', '==', 'Solutioning')
 */