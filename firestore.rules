rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Simpliwork Deal OS Security Rules
     *
     * Core Philosophy:
     * This ruleset implements a strict Role-Based Access Control (RBAC) model using "Authorization 
     * Independence." Instead of checking a user's profile for permissions, we use dedicated 
     * role collections (/roles_{roleName}/{userId}) to determine access levels via exists() checks.
     *
     * Authentication Strategy:
     * Access is strictly restricted to authenticated users with a verified '@simpliwork.com' 
     * email address. This ensures that only internal employees can access sensitive deal data.
     *
     * Data Structure:
     * - /users: User profiles, owned by the individual user.
     * - /buildings: Master data for physical assets, managed by Admins.
     * - /deals: Sales opportunities. Ownership is denormalized via 'salesOwnerId' for performant 
     *   authorization without additional lookups.
     * - /roles_*: Existence-based collections for Admin, Management, Sales, and Design roles.
     *
     * Key Security Decisions:
     * 1. Prototyping Flexibility: Rules focus on WHO can access data (Authorization) rather than 
     *    the EXACT shape of the data (Validation), allowing for rapid schema evolution.
     * 2. Denormalization: The 'salesOwnerId' is required on all Deal documents to allow 
     *    instant ownership verification.
     * 3. God View: Management and Admin roles are granted wide read access to support 
     *    organizational oversight.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated and has a @simpliwork.com email address. */
    function isSimpliworkUser() {
      // Fix: Replaced 'endsWith' with 'matches' regex as 'endsWith' was flagged as invalid.
      // Also added a check for email being a string for robustness.
      return request.auth != null && 
             request.auth.token.email is string && 
             request.auth.token.email.matches('.*@simpliwork\\.com$');
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSimpliworkUser() && request.auth.uid == userId;
    }

    /** Checks if the document belongs to the authenticated user via a denormalized ID. */
    function isDocOwner(ownerId) {
      return isSimpliworkUser() && request.auth.uid == ownerId;
    }

    /** Role: Admin - Full read/write access. */
    function isAdmin() {
      return isSimpliworkUser() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Role: Management - Read-only access to all business data. */
    function isManagement() {
      return isSimpliworkUser() && exists(/databases/$(database)/documents/roles_management/$(request.auth.uid));
    }

    /** Role: Sales - Can create and manage their own deals. */
    function isSales() {
      return isSimpliworkUser() && exists(/databases/$(database)/documents/roles_sales/$(request.auth.uid));
    }

    /** Role: Design - Read-only access to deals in the 'Solutioning' stage. */
    function isDesign() {
      return isSimpliworkUser() && exists(/databases/$(database)/documents/roles_design/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Users can manage their own profile; Admins can manage all.
     * @path /users/{userId}
     * @allow (get, update) if user is the owner or an admin.
     * @deny (list) if the user is not an admin.
     * @principle Enforces identity-based access and restricts PII listing.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Buildings. Master data is read-only for all staff, writeable by Admins.
     * @path /buildings/{buildingId}
     * @allow (get, list) if the user is a verified Simpliwork employee.
     * @deny (write) if the user is not Admin.
     * @principle Centralized master data management with broad internal visibility.
     */
    match /buildings/{buildingId} {
      allow get, list: if isSimpliworkUser();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Deals. Access is based on ownership, management oversight, or design involvement.
     * @path /deals/{dealId}
     * @allow (create) if user is Sales or Admin.
     * @deny (update) if user is not the owner, design (on specific stages), or Admin.
     * @principle Uses denormalized ownership (salesOwnerId) for efficient authorization.
     */
    match /deals/{dealId} {
      allow get: if isAdmin() || isManagement() || isDocOwner(resource.data.salesOwnerId) || (isDesign() && resource.data.stage == 'Solutioning');
      allow list: if isAdmin() || isManagement() || isSales() || isDesign(); 
      allow create: if (isSales() || isAdmin()) && request.resource.data.salesOwnerId == request.auth.uid;
      allow update: if (isAdmin() || isDocOwner(resource.data.salesOwnerId) || (isDesign() && resource.data.stage == 'Solutioning')) && resource != null;
      allow delete: if (isAdmin() || isDocOwner(resource.data.salesOwnerId)) && resource != null;
    }

    /**
     * @description Authorization markers for Admin roles.
     * @path /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow read: if isSimpliworkUser();
      allow write: if isAdmin();
    }

    /**
     * @description Authorization markers for Management roles.
     * @path /roles_management/{userId}
     */
    match /roles_management/{userId} {
      allow read: if isSimpliworkUser();
      allow write: if isAdmin();
    }

    /**
     * @description Authorization markers for Sales roles.
     * @path /roles_sales/{userId}
     */
    match /roles_sales/{userId} {
      allow read: if isSimpliworkUser();
      allow write: if isAdmin();
    }

    /**
     * @description Authorization markers for Design roles.
     * @path /roles_design/{userId}
     */
    match /roles_design/{userId} {
      allow read: if isSimpliworkUser();
      allow write: if isAdmin();
    }
  }
}
 
/** 
 * IMPLEMENTATION NOTE: 
 * These rules enforce that ONLY @simpliwork.com emails can access any data.
 * Even if a user is authenticated via Google, if their email domain does not match, 
 * the 'isSimpliworkUser()' check will fail, effectively blocking access.
 */